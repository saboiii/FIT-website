# ============================================================================
# Environment template — copy to `.env` and fill in real values.
# This project uses a single `.env` for local development (no `.env.local`).
# Production values live in the hosting provider's settings (Vercel), never in
# the repo. Never commit `.env`.
# ============================================================================

# --- Database (MongoDB / Mongoose) ------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/dbname

# --- Auth (Clerk) -------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/
# Clerk webhook signing secret (new-user webhook, /api/newUser).
# Canonical name; legacy `WEBHOOK_SECRET` is still read as a fallback.
CLERK_WEBHOOK_SECRET=whsec_...

# --- Payments (Stripe) --------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secrets (one per configured Stripe webhook endpoint)
STRIPE_SESSION_COMPLETE_SIGNING_SECRET=whsec_...
STRIPE_DIGITAL_TRANSACTION_SIGNING_SECRET=whsec_...
STRIPE_DELETE_SUBSCRIPTION_SIGNING_SECRET=whsec_...

# --- Storage (AWS S3) ---------------------------------------------------------
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
# Bucket name (read server-side too; public because object keys appear in URLs)
NEXT_PUBLIC_S3_BUCKET_NAME=my-bucket

# --- Chat (Stream) ------------------------------------------------------------
STREAM_API_KEY=...
STREAM_API_SECRET=...
STREAM_SUPPORT_USER_ID=support

# --- Email (nodemailer via Gmail) ----------------------------------------------
GMAIL_USER=ops@example.com
GMAIL_PASSWORD=app-password
# Where admin notifications (manual quote requests, etc.) are sent.
# Falls back to GMAIL_USER when unset.
ADMIN_EMAIL=

# --- Scheduled jobs --------------------------------------------------------------
# Shared secret the cron routes require as `Authorization: Bearer $CRON_SECRET`.
# Cron routes return 503 until it's set, 401 on mismatch. The scheduler is the
# GitHub Actions workflow .github/workflows/custom-print-nudges.yml, which needs
# matching repo secrets CRON_SECRET + CRON_BASE_URL (the deployment origin).
CRON_SECRET=
# Idle-nudge tuning for /api/cron/custom-print-nudges (optional; defaults shown).
CUSTOM_PRINT_NUDGE_IDLE_DAYS=3
CUSTOM_PRINT_NUDGE_COOLDOWN_DAYS=7

# --- Rate limiting (Upstash Redis) ---------------------------------------------
# Optional: rate limiting no-ops (with a warning) when unset.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# --- Misc -----------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
EXCHANGE_RATE_API_KEY=...

# --- PostHog analytics -----------------------------------------------------------
# Optional: analytics no-op entirely when unset (client capture, server capture,
# and the admin analytics dashboard all show empty/unconfigured states).
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=12345
POSTHOG_PERSONAL_API_KEY=phx_...
